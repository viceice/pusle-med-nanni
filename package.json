{
  "name": "pusle-med-nanni",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/viceice/pusle-med-nanni.git"
  },
  "author": "Michael Kriese <michael.kriese@gmx.de>",
  "main": "node_modules/.bin/docpad-server",
  "workspaces": [
    "plugins/imagin",
    "plugins/tree"
  ],
  "scripts": {
    "build": "docpad generate --env static",
    "docker": "docker run -it -v %cd%:/usr/src/app --rm -w /usr/src/app node:lts yarn",
    "docpad": "docpad",
    "grunt": "grunt",
    "prepare": "husky",
    "prettier:check": "prettier --cache -c -u .",
    "prettier:fix": "prettier --cache -w -u .",
    "start": "docpad run"
  },
  "dependencies": {
    "cookieconsent": "3.1.1",
    "font-awesome": "4.7.0",
    "jquery": "3.7.1",
    "jquery-migrate": "3.6.0",
    "metro-ui": "3.0.15",
    "waypoints": "4.0.1"
  },
  "devDependencies": {
    "docpad": "6.83.2",
    "docpad-plugin-consolidate": "2.7.0",
    "docpad-plugin-imagin": "workspace:*",
    "docpad-plugin-less": "2.10.0",
    "docpad-plugin-livereload": "2.11.0",
    "docpad-plugin-marked": "workspace:*",
    "docpad-plugin-partials": "2.14.0",
    "docpad-plugin-serve": "workspace:*",
    "docpad-plugin-tree": "workspace:*",
    "grunt": "1.6.2",
    "grunt-changed": "3.0.0",
    "grunt-contrib-copy": "1.0.0",
    "grunt-contrib-cssmin": "5.0.0",
    "grunt-contrib-uglify": "5.2.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "load-grunt-config": "4.0.1",
    "lodash": "4.18.1",
    "luxon": "3.7.2",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "safeps": "11.6.0",
    "vash": "0.13.0"
  },
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || ^24.0.0",
    "pnpm": "^10.0.0"
  },
  "pnpm": {
    "overrides": {
      "consolidate": "npm:@ladjs/consolidate@1.0.4",
      "docpad>inquirer": "8.2.7",
      "express>cookie": "1.1.1",
      "grunt-legacy-log>lodash": "$lodash",
      "grunt-legacy-util>lodash": "$lodash",
      "grunt>minimatch": "3.1.5",
      "load-grunt-config>js-yaml": "4.1.1",
      "load-grunt-config>lodash": "$lodash",
      "primus>nanoid": "3.3.12",
      "safefs": "8.10.0",
      "safeps": "$safeps"
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "storage-engine"
    ]
  }
}
